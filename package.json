{
  "name": "deeptrade-website",
  "version": "0.1.0",
  "private": true,
  "description": "DeepTrade 官方网站 — 落地页 + 中文文档 + 插件墙",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,mdx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,mdx,json,css}\"",
    "verify:content": "node scripts/verify-content.mjs",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "diff": "^9.0.0",
    "fumadocs-core": "^16.8.9",
    "fumadocs-mdx": "^15.0.2",
    "fumadocs-ui": "^16.8.9",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
